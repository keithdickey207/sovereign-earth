#!/usr/bin/env bash
# Clone-and-run entrypoint. From repo root: ./run
set -euo pipefail
ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "${ROOT}"

if [ ! -d venv ]; then
  echo "[*] First run — bootstrapping venv and mesh configs..."
  chmod +x scripts/*.sh
  ./scripts/bootstrap.sh
fi

exec ./scripts/run-all.sh "$@"
